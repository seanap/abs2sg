# Audiobookshelf
ABS_URL=http://your-abs-host:13378
ABS_TOKEN=replace_with_abs_api_token
ABS_LIBRARY_ID=
ABS_VERIFY_TLS=true

# StoryGraph
SG_EMAIL=you@example.com
SG_PASSWORD=replace_with_storygraph_password
SG_BASE_URL=https://app.thestorygraph.com
SG_LOGIN_PATH=/users/sign_in
SG_SEARCH_URL_TEMPLATE=https://app.thestorygraph.com/browse?search_term={query}
SG_LOGIN_EMAIL_SELECTORS=input[name='user[email]'], input[type='email'], input[name='email'], input[name*='email' i], input[id*='email' i], input[autocomplete='email']
SG_LOGIN_PASSWORD_SELECTORS=input[name='user[password]'], input[type='password'], input[name='password'], input[name*='password' i]
SG_LOGIN_SUBMIT_SELECTORS=button:has-text('Log in'), button:has-text('Sign in'), button[type='submit'], input[type='submit']

# Optional selector overrides for StoryGraph UI changes
SG_TO_READ_SELECTOR=button:has-text('To-Read'), button:has-text('to-read'), a:has-text('To-Read')
SG_RECENTLY_READ_SELECTOR=button:has-text('Read'), button:has-text('Mark as read'), a:has-text('Read')

# Runtime behavior
DATA_DIR=/data
DRY_RUN=true
HEADLESS=true
MAX_ACTIONS_PER_RUN=100
REQUEST_DELAY_MS=2500
REQUEST_JITTER_MS=1000
MATCH_THRESHOLD=0.70
SYNC_INTERVAL_MINUTES=0
LOG_LEVEL=INFO

# Optional image naming for compose
DOCKER_IMAGE=yourdockerhubuser/abs2sg:dev
